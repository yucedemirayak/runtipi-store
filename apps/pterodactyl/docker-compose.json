{
  "services": [
    {
      "name": "pterodactyl-perms",
      "image": "alpine:3.21",
      "networkMode": "none",
      "command": [
        "/bin/sh",
        "-c",
        "mkdir -p /var/lib/pterodactyl/volumes /var/lib/pterodactyl/archives /var/lib/pterodactyl/backups /tmp/pterodactyl /run/wings /run/wings/machine-id /run/wings/etc && chown 988:988 /var/lib/pterodactyl /var/lib/pterodactyl/volumes /var/lib/pterodactyl/archives /var/lib/pterodactyl/backups /tmp/pterodactyl /run/wings /run/wings/machine-id /run/wings/etc && chmod 755 /var/lib/pterodactyl /var/lib/pterodactyl/volumes /var/lib/pterodactyl/archives /var/lib/pterodactyl/backups /tmp/pterodactyl /run/wings /run/wings/machine-id /run/wings/etc && tail -f /dev/null"
      ],
      "volumes": [
        { "hostPath": "/var/lib/pterodactyl", "containerPath": "/var/lib/pterodactyl" },
        { "hostPath": "/tmp/pterodactyl", "containerPath": "/tmp/pterodactyl" },
        { "hostPath": "/run/wings", "containerPath": "/run/wings" }
      ]
    },
    {
      "name": "pterodactyl-db",
      "image": "mariadb:11",
      "environment": [
        { "key": "MYSQL_ROOT_PASSWORD", "value": "${TIPI_PTERODACTYL_DB_PASSWORD}" },
        { "key": "MYSQL_DATABASE", "value": "${TIPI_PTERODACTYL_DB_DATABASE}" },
        { "key": "MYSQL_USER", "value": "${TIPI_PTERODACTYL_DB_USERNAME}" },
        { "key": "MYSQL_PASSWORD", "value": "${TIPI_PTERODACTYL_DB_PASSWORD}" }
      ],
      "volumes": [
        { "hostPath": "${APP_DATA_DIR}/db-data", "containerPath": "/var/lib/mysql" }
      ],
      "healthCheck": {
        "test": "mariadb-admin ping -h localhost -u $MYSQL_USER -p$MYSQL_PASSWORD",
        "interval": "10s",
        "timeout": "5s",
        "retries": 5
      }
    },
    {
      "name": "pterodactyl-redis",
      "image": "redis:7-alpine",
      "volumes": [
        { "hostPath": "${APP_DATA_DIR}/redis-data", "containerPath": "/data" }
      ],
      "healthCheck": {
        "test": "redis-cli ping",
        "interval": "10s",
        "timeout": "5s",
        "retries": 5
      }
    },
    {
      "name": "pterodactyl",
      "image": "ghcr.io/pterodactyl/panel:latest",
      "isMain": true,
      "internalPort": 80,
      "entrypoint": ["/bin/sh", "/scripts/bootstrap.sh"],
      "command": ["supervisord", "-n", "-c", "/etc/supervisord.conf"],
      "dependsOn": {
        "pterodactyl-db": { "condition": "service_healthy" },
        "pterodactyl-redis": { "condition": "service_healthy" }
      },
      "environment": [
        { "key": "TZ", "value": "${TZ}" },
        { "key": "APP_URL", "value": "${TIPI_PTERODACTYL_APP_URL}" },
        { "key": "APP_TIMEZONE", "value": "${TIPI_PTERODACTYL_APP_TIMEZONE}" },
        { "key": "APP_SERVICE_AUTHOR", "value": "${TIPI_PTERODACTYL_APP_SERVICE_AUTHOR}" },
        { "key": "APP_KEY", "value": "${TIPI_PTERODACTYL_APP_KEY}" },
        { "key": "APP_ENV", "value": "production" },
        { "key": "APP_DEBUG", "value": "${TIPI_PTERODACTYL_APP_DEBUG}" },
        { "key": "APP_ENVIRONMENT_ONLY", "value": "${TIPI_PTERODACTYL_APP_ENVIRONMENT_ONLY}" },
        { "key": "TRUSTED_PROXIES", "value": "${TIPI_PTERODACTYL_TRUSTED_PROXIES}" },
        { "key": "CACHE_DRIVER", "value": "redis" },
        { "key": "SESSION_DRIVER", "value": "redis" },
        { "key": "QUEUE_CONNECTION", "value": "redis" },
        { "key": "DB_CONNECTION", "value": "mysql" },
        { "key": "DB_HOST", "value": "${TIPI_PTERODACTYL_DB_HOST}" },
        { "key": "DB_PORT", "value": "${TIPI_PTERODACTYL_DB_PORT}" },
        { "key": "DB_DATABASE", "value": "${TIPI_PTERODACTYL_DB_DATABASE}" },
        { "key": "DB_USERNAME", "value": "${TIPI_PTERODACTYL_DB_USERNAME}" },
        { "key": "DB_PASSWORD", "value": "${TIPI_PTERODACTYL_DB_PASSWORD}" },
        { "key": "REDIS_HOST", "value": "${TIPI_PTERODACTYL_REDIS_HOST}" },
        { "key": "REDIS_PORT", "value": "${TIPI_PTERODACTYL_REDIS_PORT}" },
        { "key": "REDIS_PASSWORD", "value": "${TIPI_PTERODACTYL_REDIS_PASSWORD}" },
        { "key": "PTERODACTYL_ADMIN_EMAIL", "value": "${TIPI_PTERODACTYL_ADMIN_EMAIL}" },
        { "key": "PTERODACTYL_ADMIN_USERNAME", "value": "${TIPI_PTERODACTYL_ADMIN_USERNAME}" },
        { "key": "PTERODACTYL_ADMIN_PASSWORD", "value": "${TIPI_PTERODACTYL_ADMIN_PASSWORD}" }
      ],
      "volumes": [
        { "hostPath": "${APP_DATA_DIR}/panel-var", "containerPath": "/app/var" },
        { "hostPath": "${APP_DATA_DIR}/panel-logs", "containerPath": "/app/storage/logs" },
        { "hostPath": "${APP_DATA_DIR}/panel-nginx", "containerPath": "/etc/nginx/http.d" },
        { "hostPath": "${APP_DATA_DIR}/panel-certs", "containerPath": "/etc/letsencrypt" },
        { "hostPath": "${ROOT_FOLDER_HOST}/apps/${APP_STORE_ID}/${APP_NAME}/scripts", "containerPath": "/scripts", "readOnly": true },
        { "hostPath": "${APP_DATA_DIR}/wings-etc", "containerPath": "/wings-config" }
      ]
    },
    {
      "name": "pterodactyl-wings",
      "image": "ghcr.io/pterodactyl/wings:latest",
      "internalPort": 8080,
      "dependsOn": {
        "pterodactyl-perms": { "condition": "service_started" }
      },
      "addPorts": [
        {
          "hostPort": "8081",
          "containerPort": 8080,
          "tcp": true
        },
        {
          "hostPort": "${TIPI_PTERODACTYL_SFTP_PORT}",
          "containerPort": 2022,
          "tcp": true
        }
      ],
      "environment": [
        { "key": "TZ", "value": "${TZ}" }
      ],
      "volumes": [
        { "hostPath": "/var/run/docker.sock", "containerPath": "/var/run/docker.sock" },
        { "hostPath": "/var/lib/docker/containers", "containerPath": "/var/lib/docker/containers", "readOnly": true },
        { "hostPath": "${APP_DATA_DIR}/wings-etc", "containerPath": "/etc/pterodactyl" },
        { "hostPath": "/var/lib/pterodactyl", "containerPath": "/var/lib/pterodactyl" },
        { "hostPath": "${APP_DATA_DIR}/wings-logs", "containerPath": "/var/log/pterodactyl" },
        { "hostPath": "/tmp/pterodactyl", "containerPath": "/tmp/pterodactyl" },
        { "hostPath": "/run/wings", "containerPath": "/run/wings" }
      ]
    }
  ],
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/v2/dynamic-compose.json"
}
